# Database
DATABASE_URL="postgresql://username:password@localhost:5432/notuly_db"

# Optional: Database URL for development
DATABASE_URL_DEV="postgresql://username:password@localhost:5432/notuly_dev"

# Optional: Database URL for testing
DATABASE_URL_TEST="postgresql://username:password@localhost:5432/notuly_test"

# App
NODE_ENV="development"
PORT=3000

# AI/OpenAI (for future AI features)
OPENAI_API_KEY="your_openai_api_key_here"

# JWT Secret (for authentication)
JWT_SECRET="your_jwt_secret_here"

# File Upload
MAX_FILE_SIZE=10485760 # 10MB
UPLOAD_DIR="./uploads"

# Frontend / Vite environment variables
# VITE_API_URL is used by the client to call the public backend API (e.g. https://api.example.com)
# VITE_PRIVATE_API_URL is intended for private/internal endpoints and should NOT be committed to public repos.
# When building with Vite, variables prefixed with VITE_ are exposed to the client bundle.
# Example:
# VITE_API_URL="https://api.example.com"
# VITE_PRIVATE_API_URL="https://internal-api.example.com"